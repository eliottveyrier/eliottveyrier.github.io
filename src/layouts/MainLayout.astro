---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
    title: string;
    showNavbar?: boolean;
}

const {
    title,
    showNavbar = true,
} = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <title>{title}</title>
    </head>

    <body>
        {showNavbar && <Navbar />}

        <main class="container">
            <slot />
        </main>

        <Footer />
    </body>
</html>