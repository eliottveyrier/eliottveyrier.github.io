---
import {
    makeStudioOneColorPalette,
} from "../../lib/music/makeStudioOneColorPalete";

interface Props {
    filename?: string;
    className?: string;
}

const {
    filename = "orchestral.colorpalette",
    className = "",
} = Astro.props;

const palette = {
    colors: makeStudioOneColorPalette(),
};

const paletteJson = JSON.stringify(
    palette,
    null,
    4,
);

const classes = [
    "studio-one-palette-download",
    className,
]
    .filter(Boolean)
    .join(" ");
---

<a
    class={classes}
    download={filename}
    href={`data:application/json;charset=utf-8,${encodeURIComponent(paletteJson)}`}
    title={`Download ${filename}`}
>
    <img
        class="studio-one-palette-download__logo"
        src="/fender-studio-logo.webp"
        alt="Fender Studio Pro"
    />

    <span
        class="studio-one-palette-download__arrow"
        aria-hidden="true"
    >
        ↓
    </span>
</a>

<style>
    .studio-one-palette-download {
        margin-top: 2rem;
        display: inline-flex;
        align-items: center;
        gap: 1.25rem;

        padding: 0.65rem 1rem 0.65rem 1.25rem;

        border-radius: 999px;

        background: color-mix(
            in oklch,
            white 88%,
            var(--text)
        );

        color: var(--text);

        text-decoration: none;

        box-shadow:
            0 1px 2px color-mix(
                in oklch,
                var(--text) 10%,
                transparent
            );

        transition:
            transform 150ms ease,
            box-shadow 150ms ease,
            background 150ms ease;
    }

    .studio-one-palette-download:hover {
        transform: translateY(-2px);

        background: color-mix(
            in oklch,
            white 94%,
            var(--text)
        );

        box-shadow:
            0 4px 12px color-mix(
                in oklch,
                var(--text) 14%,
                transparent
            );
    }

    .studio-one-palette-download__logo {
        display: block;

        width: 10rem;
        height: auto;

        object-fit: contain;
    }

    .studio-one-palette-download__arrow {
        display: flex;
        align-items: center;
        justify-content: center;

        color: #000;

        font-size: 2.4rem;
        font-weight: 1000;
        line-height: 0.8;

        transform: translateY(-0.08em);
    }
</style>